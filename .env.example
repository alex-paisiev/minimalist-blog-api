# PostgreSQL
DB_USER=blog_user
DB_PASSWORD=changeme
DB_NAME=blog_db
DB_HOST=db
DB_PORT=5432

# Redis
CACHE_HOST=redis
CACHE_PORT=6379

# App
# APP_ENV controls log format and level:
#   development / staging → DEBUG level, colored console output
#   production            → INFO level, JSON output
APP_ENV=development
LOG_LEVEL=DEBUG



# Pagination defaults
DEFAULT_PAGE_SIZE=10
MAX_PAGE_SIZE=100

# Cache TTL in seconds
CACHE_TTL=3600
